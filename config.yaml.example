server:
    host: 0.0.0.0
    port: 8080
ai:
    default_provider: qwen
    openai:
        api_key: ""
        model: gpt-4o
    anthropic:
        api_key: ""
        model: claude-sonnet-4-20250514
    google:
        api_key: ""
        model: gemini-1.5-pro
    ollama:
        base_url: http://localhost:11434
        model: llama3
    qwen:
        api_key: "sk-d14d1f28c05b4220bdf3059fda408eb3"  # Set your DashScope API key here
        base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
        model: glm-4.7
executor:
    safe_commands:
        - ls
        - pwd
        - cat
        - echo
        - whoami
        - date
        - uptime
        - df
        - free
        - ps
        - head
        - tail
        - wc
        - grep
        - find
        - which
        - env
        - hostname
    moderate_commands:
        - mkdir
        - cp
        - mv
        - touch
        - chmod
        - chown
        - tar
        - gzip
        - gunzip
        - zip
        - unzip
        - wget
        - curl
    dangerous_commands:
        - rm
        - sudo
        - apt
        - yum
        - dnf
        - pacman
        - pip
        - npm
        - go
        - make
        - systemctl
        - service
        - reboot
        - shutdown
        - kill
        - pkill
    blocked_commands:
        - dd
        - mkfs
        - fdisk
        - parted
        - format
        - ':(){:|:&};:'
fileops:
    base_directory: ~/pibot-workspace
    allowed_paths: []
# Web search tool configuration.
# Priority: DuckDuckGo is always tried first (free, no key needed).
# If duckduckgo_api_key is set, it is sent as a Bearer token.
# If duckduckgo_api_key is empty, Perplexity is used as the fallback
# (requires perplexity_api_key).
web_search:
    duckduckgo_api_key: ""
    perplexity_api_key: ""
prompts:
    # Custom system prompt (leave empty to use default PiBot system prompt)
    # You can customize this to change PiBot's personality and instructions
    system_prompt: ""
    # Bot name for identity (default: PiBot)
    bot_name: PiBot
    # Enable tool calling for AI assistants (default: true)
    # When enabled, PiBot can execute commands, read/write files, and more
    enable_tools: true
# Path to directory containing external skills (default: ~/.pibot_skills)
# Each subdirectory should contain a skill.yaml manifest and an executable file.
skills_path: ~/pibot-workspace/skills
# Environment variables injected into the process at startup.
# Use this to set API keys or other secrets without hardcoding them in ai: sections.
env:
    # PERPLEXITY_API_KEY: your_key
# Reboot configuration - controls how the bot restarts itself
reboot:
    # plan: which reboot strategy to use. Currently supported: "screen" (default)
    plan: screen
    screen:
        # The screen session name that hosts the server
        session_name: pibot
        # Working directory to cd into before starting the server
        work_dir: /home/orangepi/workspace/pibot
        # Command used to launch the server
        start_command: go run cmd/server/main.go
